{
  "name": "7game-lite",
  "private": true,
  "version": "0.5.5",
  "type": "module",
  "description": "Minimal MUD + AI cultivation game",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "ai": "npx tsx server/ai-server.ts",
    "download-model": "npx tsx server/download-model.ts",
    "download-model:2b": "npx tsx server/download-model.ts --model 2b",
    "download-model:0.8b": "npx tsx server/download-model.ts --model 0.8b",
    "test:ai-stress": "npx tsx server/tests/ai-stress-test.ts",
    "test:regression": "npx tsx scripts/regression-all.ts",
    "test:ui": "npx tsx scripts/verify-ui-formatter.ts",
    "lint": "eslint src/ server/",
    "lint:fix": "eslint src/ server/ --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-clean-timer": "^1.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-sonarjs": "^4.0.2",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.1"
  }
}
